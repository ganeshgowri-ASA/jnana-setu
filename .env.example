NODE_ENV=development
PORT=3000

RFX_BASE_URL=https://rfxmanager.ril.com
RFX_API_TOKEN=
RFX_WEBHOOK_SECRET=dev-rfx-secret

QM_BASE_URL=https://pncplatform.ril.com/queryManager
QM_API_TOKEN=
QM_WEBHOOK_SECRET=dev-qm-secret

REDIS_URL=redis://localhost:6379
REDIS_STREAM_RFX=bridge:rfx
REDIS_STREAM_QM=bridge:qm
REDIS_CONSUMER_GROUP=bridge-sync

SYNC_POLL_INTERVAL_MS=15000
LOG_LEVEL=info
