# jnana-setu environment variables.
# Copy this file to .env.local for local development.
# No secrets are required to run the catalog — it is fully static by default.

# Optional: base URL used when building absolute links in metadata / sitemap.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Plausible / analytics domain (leave empty to disable).
NEXT_PUBLIC_ANALYTICS_DOMAIN=

# Optional: n8n webhook that the scheduled refresh workflow POSTs results to.
# Only used by the n8n workflows under /n8n — not required to run the app.
N8N_REFRESH_WEBHOOK_SECRET=
